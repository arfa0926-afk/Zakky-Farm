-- COUNT ITEM
local function countItem(name)

	local amount = 0

	for _,v in pairs(backpack:GetChildren()) do
		if v.Name == name then
			amount += 1
		end
	end

	if player.Character then
		for _,v in pairs(player.Character:GetChildren()) do
			if v.Name == name then
				amount += 1
			end
		end
	end

	return amount

end


-- UPDATE TEXT
local function updateItems()

	water.Text = "💧 Water: "..countItem("Water")
	sugar.Text = "🍬 Sugar: "..countItem("Sugar Block Bag")
	gelatin.Text = "🟡 Gelatin: "..countItem("Gelatin")
	bag.Text = "👜 Bag: "..countItem("Empty Bag")

end


task.spawn(function()
	while true do
		updateItems()
		task.wait(1)
	end
end)


-- AUTO COOK
local running = false


local function pressE()

	vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
	task.wait(0.1)
	vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)

end


local function equipTool(name)

	local tool = backpack:FindFirstChild(name)

	if tool then
		player.Character.Humanoid:EquipTool(tool)
		task.wait(0.4)
	end

end


local function autoCook()

	while running do

		equipTool("Water")
		pressE()

		task.wait(30)

		equipTool("Sugar Block Bag")
		pressE()

		task.wait(0.5)

		equipTool("Gelatin")
		pressE()

		task.wait(50)

		equipTool("Empty Bag")

		print("Marshmallow selesai")

	end

end


autoFarm.MouseButton1Click:Connect(function()

	running = not running

	if running then
		autoFarm.Text = "AUTO FARM : ON"
		task.spawn(autoCook)
	else
		autoFarm.Text = "AUTO FARM : OFF"
	end

end)

